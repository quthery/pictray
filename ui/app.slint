import { ScrollView } from "std-widgets.slint";

export struct ImageTile {
    title: string,
    subtitle: string,
    badge: string,
    preview: string,
    line_numbers: string,
    is_text: bool,
    is_file: bool,
    has_thumbnail: bool,
    thumbnail: image,
}

component TextButton inherits Rectangle {
    in property <string> label;
    in property <color> base-background;
    in property <color> hover-background;
    in property <color> pressed-background;
    in property <color> base-border;
    in property <color> hover-border;
    in property <color> pressed-border;
    in property <color> label-color;
    in property <color> pressed-label-color: label-color;
    callback clicked();

    border-width: 1px;
    border-radius: self.height / 2;
    border-color: touch.pressed ? pressed-border : touch.has-hover ? hover-border : base-border;
    background: touch.pressed ? pressed-background : touch.has-hover ? hover-background : base-background;
    drop-shadow-blur: touch.has-hover ? 14px : 6px;
    drop-shadow-color: touch.has-hover ? #00000044 : #00000018;
    animate background { duration: 120ms; easing: ease-out; }
    animate border-color { duration: 120ms; easing: ease-out; }
    animate drop-shadow-blur { duration: 120ms; easing: ease-out; }

    Text {
        text: root.label;
        color: touch.pressed ? root.pressed-label-color : root.label-color;
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: MouseCursor.pointer;
        clicked => {
            root.clicked();
        }
    }
}

component InspectIcon inherits Rectangle {
    in property <color> stroke: #f7efdd;

    background: #00000000;

    Rectangle {
        x: 3px;
        y: 3px;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        border-width: 1.6px;
        border-color: root.stroke;
        background: #00000000;
    }

    Path {
        x: 11px;
        y: 11px;
        width: 6px;
        height: 6px;
        stroke: root.stroke;
        stroke-width: 1.6px;

        MoveTo {
            x: 0;
            y: 0;
        }
        LineTo {
            x: 6;
            y: 6;
        }
    }
}

component CopyIcon inherits Rectangle {
    in property <color> stroke: #f7efdd;

    background: #00000000;

    Rectangle {
        x: 3.5px;
        y: 2.5px;
        width: 9px;
        height: 11px;
        border-radius: 3px;
        border-width: 1.4px;
        border-color: root.stroke;
        background: #00000000;
    }

    Rectangle {
        x: 7.5px;
        y: 6.5px;
        width: 9px;
        height: 11px;
        border-radius: 3px;
        border-width: 1.4px;
        border-color: root.stroke;
        background: #00000000;
    }
}

component DeleteIcon inherits Rectangle {
    in property <color> stroke: #f7efdd;

    background: #00000000;

    Path {
        x: 3px;
        y: 2px;
        width: 14px;
        height: 16px;
        stroke: root.stroke;
        stroke-width: 1.5px;
        stroke-line-cap: round;
        stroke-line-join: round;

        MoveTo { x: 4; y: 4; }
        LineTo { x: 10; y: 4; }
        MoveTo { x: 6; y: 2; }
        LineTo { x: 8; y: 2; }
        MoveTo { x: 2; y: 4; }
        LineTo { x: 12; y: 4; }
        MoveTo { x: 3.5; y: 5.5; }
        LineTo { x: 4.5; y: 14; }
        LineTo { x: 9.5; y: 14; }
        LineTo { x: 10.5; y: 5.5; }
        MoveTo { x: 5.5; y: 7; }
        LineTo { x: 5.5; y: 12; }
        MoveTo { x: 7; y: 7; }
        LineTo { x: 7; y: 12; }
        MoveTo { x: 8.5; y: 7; }
        LineTo { x: 8.5; y: 12; }
    }
}

component ArrowUpIcon inherits Rectangle {
    in property <color> stroke: #f7efdd;

    background: #00000000;

    Path {
        x: 5px;
        y: 4px;
        width: 10px;
        height: 12px;
        stroke: root.stroke;
        stroke-width: 1.8px;
        stroke-line-cap: round;
        stroke-line-join: round;

        MoveTo { x: 5; y: 0; }
        LineTo { x: 0; y: 5; }
        MoveTo { x: 5; y: 0; }
        LineTo { x: 10; y: 5; }
        MoveTo { x: 5; y: 0; }
        LineTo { x: 5; y: 12; }
    }
}

component ArrowDownIcon inherits Rectangle {
    in property <color> stroke: #f7efdd;

    background: #00000000;

    Path {
        x: 5px;
        y: 4px;
        width: 10px;
        height: 12px;
        stroke: root.stroke;
        stroke-width: 1.8px;
        stroke-line-cap: round;
        stroke-line-join: round;

        MoveTo { x: 5; y: 12; }
        LineTo { x: 0; y: 7; }
        MoveTo { x: 5; y: 12; }
        LineTo { x: 10; y: 7; }
        MoveTo { x: 5; y: 0; }
        LineTo { x: 5; y: 12; }
    }
}

component ActionButton inherits Rectangle {
    in property <int> kind: 0;
    in property <bool> enabled: true;
    callback clicked();

    border-radius: self.height / 2;
    border-width: 1px;
    border-color: !root.enabled ? #2a303b : touch.pressed ? #f7efdd : touch.has-hover ? #8d8477 : #3b414d;
    background: !root.enabled ? #090c12 : touch.pressed ? #efe5d4 : touch.has-hover ? #141b25 : #0c1017;
    drop-shadow-blur: root.enabled && touch.has-hover ? 16px : 8px;
    drop-shadow-color: !root.enabled ? #00000018 : touch.has-hover ? #00000055 : #00000022;
    animate background { duration: 120ms; easing: ease-out; }
    animate border-color { duration: 120ms; easing: ease-out; }
    animate drop-shadow-blur { duration: 120ms; easing: ease-out; }

    if kind == 0 : InspectIcon {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 20px;
        height: 20px;
        stroke: !root.enabled ? #4a5260 : touch.pressed ? #17181d : #f7efdd;
    }

    if kind == 1 : CopyIcon {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 20px;
        height: 20px;
        stroke: !root.enabled ? #4a5260 : touch.pressed ? #17181d : #f7efdd;
    }

    if kind == 2 : DeleteIcon {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 20px;
        height: 20px;
        stroke: !root.enabled ? #4a5260 : touch.pressed ? #17181d : #f7efdd;
    }

    if kind == 3 : ArrowUpIcon {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 20px;
        height: 20px;
        stroke: !root.enabled ? #4a5260 : touch.pressed ? #17181d : #f7efdd;
    }

    if kind == 4 : ArrowDownIcon {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 20px;
        height: 20px;
        stroke: !root.enabled ? #4a5260 : touch.pressed ? #17181d : #f7efdd;
    }

    touch := TouchArea {
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
        clicked => {
            if root.enabled {
                root.clicked();
            }
        }
    }
}

component Tile inherits Rectangle {
    in property <ImageTile> data;
    in property <int> index;
    in property <int> item-count: 0;
    in property <bool> selected: false;
    in property <length> content-origin-y: 0px;
    callback inspect-requested(int);
    callback copy-requested(int);
    callback drag-out-requested(int);
    callback reorder-requested(int, float);
    callback move-up-requested(int);
    callback move-down-requested(int);
    callback delete-requested(int);
    callback open-requested(int);
    callback select-requested(int);
    property <bool> drag-gesture-fired: false;
    property <int> drag-mode: 0;

    border-radius: 18px;
    background: #0b0d11;
    width: 100%;
    height: selected && (data.is_text || data.is_file) ? 214px : 168px;
    border-width: 1px;
    border-color: selected ? #f2ead57a : hover-touch.has-hover ? #f2ead55c : #f2ead51f;
    clip: true;
    animate height { duration: 140ms; easing: ease-out; }
    animate border-color { duration: 140ms; easing: ease-out; }

    hover-touch := TouchArea {
        mouse-cursor: (!data.is_text && !data.is_file) || data.has_thumbnail ? MouseCursor.pointer : MouseCursor.default;
        clicked => {
            if !root.drag-gesture-fired {
                if (!data.is_text && !data.is_file) || data.has_thumbnail {
                    root.open-requested(root.index);
                } else {
                    root.select-requested(root.index);
                }
            }
            root.drag-gesture-fired = false;
        }
        pointer-event(event) => {
            if event.kind == PointerEventKind.down {
                root.drag-gesture-fired = false;
                root.drag-mode = 0;
            } else if event.kind == PointerEventKind.up {
                if root.drag-mode == 2 {
                    root.reorder-requested(
                        root.index,
                        (self.absolute-position.y + self.mouse-y - root.content-origin-y) / 1px,
                    );
                }
                root.drag-mode = 0;
            }
        }
        moved => {
            if self.pressed && root.drag-mode == 0
                    && (self.mouse-x - self.pressed-x > 18px
                        || self.pressed-x - self.mouse-x > 18px
                        || self.mouse-y - self.pressed-y > 18px
                        || self.pressed-y - self.mouse-y > 18px) {
                root.drag-gesture-fired = true;
                if (self.mouse-y - self.pressed-y > self.mouse-x - self.pressed-x
                        && self.mouse-y - self.pressed-y > self.pressed-x - self.mouse-x)
                        || (self.pressed-y - self.mouse-y > self.mouse-x - self.pressed-x
                            && self.pressed-y - self.mouse-y > self.pressed-x - self.mouse-x) {
                    root.drag-mode = 2;
                } else {
                    root.drag-mode = 1;
                    root.drag-out-requested(root.index);
                }
            }
        }

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: #090b0f;

            if data.is_text : Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                background: selected ? #121923 : #10151d;

                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: 5px;
                    height: parent.height;
                    background: selected ? #ead7ad : #b89d6f;
                }

                Rectangle {
                    x: 10px;
                    y: 10px;
                    width: parent.width - 20px;
                    height: 34px;
                    background: #00000000;

                    Rectangle {
                        x: 0px;
                        y: 2px;
                        width: 42px;
                        height: 26px;
                        border-radius: 9px;
                        background: selected ? #f1dfba : #dcc69e;

                        Text {
                            text: data.badge;
                            color: #17181d;
                            font-size: 10px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }

                    Text {
                        x: 52px;
                        y: 0px;
                        width: parent.width - 52px;
                        height: 16px;
                        text: data.title;
                        color: #faf6ee;
                        font-size: 13px;
                        font-weight: 800;
                        overflow: elide;
                    }

                    Text {
                        x: 52px;
                        y: 17px;
                        width: parent.width - 52px;
                        height: 14px;
                        text: data.subtitle;
                        color: #aeb7c6;
                        font-size: 10px;
                        font-weight: 600;
                        overflow: elide;
                    }
                }

                Rectangle {
                    x: 10px;
                    y: 50px;
                    width: parent.width - 20px;
                    height: parent.height - 60px;
                    border-radius: 13px;
                    background: selected ? #090d13 : #0b1017;
                    border-width: 1px;
                    border-color: selected ? #f0dcb23d : #f0dcb21f;
                    clip: true;

                    Rectangle {
                        x: 0px;
                        y: 0px;
                        width: 31px;
                        height: parent.height;
                        background: #141b25;
                    }

                    Rectangle {
                        x: 31px;
                        y: 0px;
                        width: 1px;
                        height: parent.height;
                        background: #f0e7d219;
                    }

                    Text {
                        x: 0px;
                        y: 8px;
                        width: 30px;
                        height: parent.height - 16px;
                        text: data.line_numbers;
                        color: #6d7685;
                        font-size: 10px;
                        font-weight: 700;
                        font-family: "Menlo";
                        horizontal-alignment: center;
                        overflow: elide;
                    }

                    Text {
                        x: 40px;
                        y: 8px;
                        width: parent.width - 50px;
                        height: parent.height - 16px;
                        text: data.preview;
                        color: #dce4f2;
                        font-size: 11px;
                        font-weight: 500;
                        font-family: "Menlo";
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }
            }

            if data.is_file : Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                background: selected ? #121923 : #10151d;

                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: 5px;
                    height: parent.height;
                    background: selected ? #ead7ad : #b89d6f;
                }

                if data.has_thumbnail : Rectangle {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: parent.height;
                    border-radius: 18px;
                    background: #f6f1e8;
                    clip: true;

                    Image {
                        source: data.thumbnail;
                        image-fit: cover;
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        height: parent.height;
                    }
                }

                if !data.has_thumbnail : Rectangle {
                    x: (parent.width - self.width) / 2;
                    y: 22px;
                    width: 76px;
                    height: 90px;
                    border-radius: 10px;
                    background: selected ? #f1dfba : #dcc69e;
                    border-width: 1px;
                    border-color: #fff7e066;

                    Rectangle {
                        x: parent.width - 24px;
                        y: 0px;
                        width: 24px;
                        height: 24px;
                        border-radius: 5px;
                        background: selected ? #bfa67b : #a99066;
                    }

                    Text {
                        x: 8px;
                        y: 34px;
                        width: parent.width - 16px;
                        height: 22px;
                        text: data.badge;
                        color: #17181d;
                        font-size: 12px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                if !data.has_thumbnail : Text {
                    x: 12px;
                    y: 124px;
                    width: parent.width - 24px;
                    height: 18px;
                    text: data.title;
                    color: #faf6ee;
                    font-size: 13px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    overflow: elide;
                }

                if !data.has_thumbnail : Text {
                    x: 12px;
                    y: 144px;
                    width: parent.width - 24px;
                    height: 14px;
                    text: data.subtitle;
                    color: #aeb7c6;
                    font-size: 10px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    overflow: elide;
                }

                if selected && !data.has_thumbnail : Text {
                    x: 14px;
                    y: 168px;
                    width: parent.width - 28px;
                    height: 32px;
                    text: data.preview;
                    color: #dce4f2;
                    font-size: 10px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                    overflow: elide;
                }
            }

            if !data.is_text && !data.is_file : Image {
                source: data.thumbnail;
                image-fit: cover;
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                animate x, y, width, height { duration: 140ms; easing: ease-out; }
            }

            if selected && !data.is_text && !data.is_file : Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                border-radius: 18px;
                border-width: 1px;
                border-color: #fff2cf4d;
                background: #fff4d208;

                Rectangle {
                    x: 12px;
                    y: 12px;
                    width: parent.width - 24px;
                    height: 40px;
                    border-radius: 14px;
                    background: #06090faa;

                    VerticalLayout {
                        padding-top: 7px;
                        padding-bottom: 7px;
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 1px;

                        Text {
                            text: data.title;
                            color: #fbf6eb;
                            font-size: 13px;
                            font-weight: 800;
                            overflow: elide;
                        }

                        Text {
                            text: data.subtitle;
                            color: #d0cabf;
                            font-size: 10px;
                            font-weight: 600;
                            overflow: elide;
                        }
                    }
                }
            }
        }

        if hover-touch.has-hover && !selected && data.is_file && data.has_thumbnail : Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: #06090fb0;
            animate background { duration: 120ms; easing: ease-out; }

            Rectangle {
                x: 12px;
                y: 12px;
                width: parent.width - 24px;
                height: 36px;
                background: #00000000;

                VerticalLayout {
                    spacing: 2px;

                    Text {
                        text: data.title;
                        color: #faf6ee;
                        font-size: 13px;
                        font-weight: 700;
                        overflow: elide;
                    }

                    Text {
                        text: data.subtitle;
                        color: #d0cabf;
                        font-size: 11px;
                        font-weight: 500;
                        overflow: elide;
                    }
                }
            }
        }

        if hover-touch.has-hover && !selected && !data.is_text && !data.is_file : Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: #06090fb0;
            animate background { duration: 120ms; easing: ease-out; }

            Rectangle {
                x: 12px;
                y: 12px;
                width: parent.width - 24px;
                height: 36px;
                background: #00000000;

                VerticalLayout {
                    spacing: 2px;

                    Text {
                        text: data.title;
                        color: #faf6ee;
                        font-size: 13px;
                        font-weight: 700;
                        overflow: elide;
                    }

                    Text {
                        text: data.subtitle;
                        color: #d0cabf;
                        font-size: 11px;
                        font-weight: 500;
                        overflow: elide;
                    }
                }
            }
        }

        if hover-touch.has-hover : Rectangle {
            x: parent.width - 126px;
            y: 12px;
            width: 114px;
            height: 32px;
            background: #00000000;

            HorizontalLayout {
                spacing: 6px;

                ActionButton {
                    width: 34px;
                    height: 32px;
                    kind: 0;
                    clicked => {
                        root.inspect-requested(root.index);
                    }
                }

                ActionButton {
                    width: 34px;
                    height: 32px;
                    kind: 1;
                    clicked => {
                        root.copy-requested(root.index);
                    }
                }

                ActionButton {
                    width: 34px;
                    height: 32px;
                    kind: 2;
                    clicked => {
                        root.delete-requested(root.index);
                    }
                }
            }
        }

        if hover-touch.has-hover : Rectangle {
            x: parent.width - 44px;
            y: (parent.height - self.height) / 2;
            width: 32px;
            height: 70px;
            background: #00000000;

            VerticalLayout {
                spacing: 6px;

                ActionButton {
                    width: 32px;
                    height: 32px;
                    kind: 3;
                    enabled: root.index > 0;
                    clicked => {
                        root.move-up-requested(root.index);
                    }
                }

                ActionButton {
                    width: 32px;
                    height: 32px;
                    kind: 4;
                    enabled: root.index + 1 < root.item-count;
                    clicked => {
                        root.move-down-requested(root.index);
                    }
                }
            }
        }

    }
}

export component MainWindow inherits Window {
    title: "Pictray";
    width: 320px;
    height: 452px;
    no-frame: true;
    always-on-top: true;
    background: #00000000;

    in property <[ImageTile]> images;
    in property <string> status-text: "";
    in property <bool> drop-active: false;
    in property <bool> show-clear-confirmation: false;
    in property <int> selected-index: -1;
    callback inspect-image(int);
    callback open-image(int);
    callback copy-image(int);
    callback drag-out-image(int);
    callback reorder-image(int, float);
    callback move-image-up(int);
    callback move-image-down(int);
    callback delete-image(int);
    callback select-image(int);
    callback begin-window-drag();
    callback clear-all();
    callback confirm-clear-all();
    callback cancel-clear-all();
    callback hide-window();

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        border-radius: 26px;
        background: #111318f0;
        clip: true;

        VerticalLayout {
            padding: 10px;
            spacing: 10px;

            Rectangle {
                height: 6px;
                background: #00000000;

                Rectangle {
                    x: (parent.width - 52px) / 2;
                    y: 0px;
                    width: 52px;
                    height: 4px;
                    border-radius: 2px;
                    background: drag-touch.pressed ? #f1e7d4aa : #f1e7d466;
                }

                drag-touch := TouchArea {
                    pointer-event(event) => {
                        if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                            root.begin-window-drag();
                        }
                    }
                }
            }

            HorizontalLayout {
                height: 38px;
                spacing: 8px;

                TextButton {
                    label: "Copy latest";
                    base-background: #ddcfb8;
                    hover-background: #e9dcc8;
                    pressed-background: #f3eadb;
                    base-border: #fff7e01f;
                    hover-border: #fff7e066;
                    pressed-border: #fff7e099;
                    label-color: #17181d;
                    pressed-label-color: #17181d;
                    clicked => {
                        root.copy-image(0);
                    }
                }

                TextButton {
                    width: 66px;
                    label: "Clear";
                    base-background: #252931;
                    hover-background: #2f3440;
                    pressed-background: #f3ecde;
                    base-border: #f4efe61a;
                    hover-border: #f4efe64d;
                    pressed-border: #f4efe680;
                    label-color: #f4efe6;
                    pressed-label-color: #17181d;
                    clicked => {
                        root.clear-all();
                    }
                }

                TextButton {
                    width: 66px;
                    label: "Hide";
                    base-background: #252931;
                    hover-background: #2f3440;
                    pressed-background: #f3ecde;
                    base-border: #f4efe61a;
                    hover-border: #f4efe64d;
                    pressed-border: #f4efe680;
                    label-color: #f4efe6;
                    pressed-label-color: #17181d;
                    clicked => {
                        root.hide-window();
                    }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                border-radius: 22px;
                background: #00000000;
                clip: true;

                if images.length == 0 : Rectangle {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: parent.height;
                    border-radius: 22px;
                    background: #181a20e8;

                    Text {
                        text: "No stored items";
                        color: #b0b4c1;
                        font-size: 13px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if images.length > 0 : ScrollView {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: parent.height;
                    image-column := VerticalLayout {
                        spacing: 8px;

                        for tile[index] in root.images : Tile {
                            data: tile;
                            index: index;
                            item-count: root.images.length;
                            selected: root.selected-index == index;
                            content-origin-y: image-column.absolute-position.y;
                            inspect-requested(index) => {
                                root.inspect-image(index);
                            }
                            copy-requested(index) => {
                                root.copy-image(index);
                            }
                            drag-out-requested(index) => {
                                root.drag-out-image(index);
                            }
                            reorder-requested(index, pointer-y) => {
                                root.reorder-image(index, pointer-y);
                            }
                            move-up-requested(index) => {
                                root.move-image-up(index);
                            }
                            move-down-requested(index) => {
                                root.move-image-down(index);
                            }
                            delete-requested(index) => {
                                root.delete-image(index);
                            }
                            open-requested(index) => {
                                root.open-image(index);
                            }
                            select-requested(index) => {
                                root.select-image(index);
                            }
                        }
                    }
                }

                if root.drop-active : Rectangle {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: parent.height;
                    border-radius: 22px;
                    background: #d9c8ab22;
                    border-width: 1px;
                    border-color: #d9c8ab66;

                    overlay-touch := TouchArea {}

                    Rectangle {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 248px;
                        height: 58px;
                        border-radius: 18px;
                        background: #0d1118d8;
                        border-width: 1px;
                        border-color: #f4ede238;
                        drop-shadow-blur: 18px;
                        drop-shadow-color: #00000055;

                        VerticalLayout {
                            padding-top: 10px;
                            padding-bottom: 10px;
                            padding-left: 18px;
                            padding-right: 18px;
                            spacing: 2px;
                            alignment: center;

                            Text {
                                text: "Drop any file";
                                color: #fffaf0;
                                font-size: 15px;
                                font-weight: 800;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: "Copies the path";
                                color: #f5e7c9;
                                font-size: 12px;
                                font-weight: 700;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        if root.show-clear-confirmation : Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: #040608cc;

            blocker-touch := TouchArea {}

            Rectangle {
                x: 22px;
                y: 136px;
                width: parent.width - 44px;
                height: 132px;
                border-radius: 18px;
                background: #141821f4;
                border-width: 1px;
                border-color: #f1e7d42a;

                VerticalLayout {
                    padding: 16px;
                    spacing: 14px;

                    Text {
                        text: "Clear buffer?";
                        color: #faf6ee;
                        font-size: 16px;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "This removes all stored images, GIFs, text files, and file paths from the current buffer.";
                        color: #c7c2b8;
                        font-size: 12px;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        spacing: 8px;

                        TextButton {
                            height: 34px;
                            label: "Cancel";
                            base-background: #252a33;
                            hover-background: #313844;
                            pressed-background: #f3ecde;
                            base-border: #f3efe71f;
                            hover-border: #f3efe74d;
                            pressed-border: #f3efe780;
                            label-color: #f3efe7;
                            pressed-label-color: #17181d;
                            clicked => {
                                root.cancel-clear-all();
                            }
                        }

                        TextButton {
                            height: 34px;
                            label: "Clear";
                            base-background: #e2d0b2;
                            hover-background: #eddcc2;
                            pressed-background: #f7f0e4;
                            base-border: #fff7e033;
                            hover-border: #fff7e077;
                            pressed-border: #fff7e0aa;
                            label-color: #17181d;
                            pressed-label-color: #17181d;
                            clicked => {
                                root.confirm-clear-all();
                            }
                        }
                    }
                }
            }
        }
    }
}
